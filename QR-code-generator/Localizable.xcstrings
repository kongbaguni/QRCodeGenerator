    "anomymouse sign out" : {
      "comment" : "signout",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are logging in anonymously.\nIf you log out, you will not be able to log in again with the same account, and any saved data will be deleted.\nDo you want to continue?"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "익명로그인 중입니다. \n로그아웃 하면 같은 계정으로 다시 로그인 할 수 없고,  저장된 데이터는 삭제됩니다. \n계속하시겠습니까?"
          }
