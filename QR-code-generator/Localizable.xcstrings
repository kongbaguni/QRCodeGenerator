      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delete your account.\nAfterwards, previously saved data cannot be accessed again.\nIf you agree to account deletion, fill out the text field below and click the confirm button."
