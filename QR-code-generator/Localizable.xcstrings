      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sign In"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로그인"
          }
